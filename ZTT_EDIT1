// 🟢 เพิ่มฟังก์ชันนี้เข้าไปในโค้ด เพื่อคอยดึงเน็ตกลับมาเวลาหลุดกลางทาง
void check_wifi_reconnect() {
  // เช็กว่า WiFi หลุดหรือไม่ (และต้องไม่อยู่ในโหมดจูนหรือกดปุ่มเซ็ตอัปค้าง)
  if (WiFi.status() != WL_CONNECTED) {
    static unsigned long lastWifiRetry = 0;
   
    // พยายามเชื่อมต่อใหม่ทุกๆ 10 วินาที (ไม่สั่งถี่เกินไปเพื่อไม่ให้บอร์ดรวน)
    if (millis() - lastWifiRetry > 10000) {
      lastWifiRetry = millis();
      Serial.println("⚠️ WiFi Disconnected! Trying to reconnect...");
     
      // สั่งดึงโปรไฟล์ WiFi ล่าสุดที่เก็บในหน่วยความจำของบอร์ดมาเชื่อมต่อใหม่เอง
      WiFi.begin();
    }
  }
  else {
    // ถ้า WiFi ต่อได้ปกติแล้ว ค่อยไปเช็กและสั่งเชื่อมต่อ MQTT Client ต่อไป
    if (!client.connected() || !client2.connected()) {
      reconnect(); // ฟังก์ชัน reconnect ของ MQTT เดิมของพี่
    }
  }
}



