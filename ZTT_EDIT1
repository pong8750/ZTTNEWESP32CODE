//หรือ 1-2k) ที่มีค่า Beta 3950  -40°C ถึง +125°C
void readSensors() {
  v1 = getValue(PIN_V1, MULT_V1);
  v2 = getValue(PIN_V2, MULT_V2);
  v3 = getValue(PIN_V3, MULT_V3);
  v4 = getValue(PIN_V4, MULT_V4);
  int rawNTC = analogRead(NTC_Pin);
  if (rawNTC < 4095 && rawNTC > 100) {
    float v_ratio = rawNTC / 4095.0;
    float R_ntc = 2000.0 * (v_ratio / (1.0 - v_ratio));
    float tempK = 1.0 / (1.0/298.15 + (log(R_ntc/2000.0) / 3950.0));
    tempNTC = (tempK - 273.15) + NTC_OFFSET; // <<< แก้บรรทัดนี้ จาก 15.3 เป็น NTC_OFFSET
  }
  DateTime now = rtc.now();
  Serial.printf("v1:%.1f, v2:%.1f, v3:%.1f, T:%.1f, :%02d:%02d:%02d\n", v1, v2, v3, tempNTC, now.hour(), now.minute(), now.second());
}




void checkManualButton() {
  int currentButtonState = digitalRead(25);
  if (currentButtonState == LOW && lastButtonState == HIGH) {
    if (millis() - lastDebounceTime > 200) {
      if (manualState == false) {
        manualState = true;
        isCooldown = false;
        digitalWrite(PIN_PEA, LOW); delay(100);
        digitalWrite(PIN_INV, HIGH);
        gridMode = false;
      } else {
        if (gridMode == false) {
          digitalWrite(PIN_INV, LOW); delay(100);
          digitalWrite(PIN_PEA, HIGH);
          gridMode = true;
        } else {
          digitalWrite(PIN_PEA, LOW); delay(100);
          digitalWrite(PIN_INV, HIGH);
          gridMode = false;
        }
      }
      lastDebounceTime = millis();
    }
  }
  lastButtonState = currentButtonState;
}

