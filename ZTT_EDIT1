void runAutoSystem() {
  unsigned long currentMillis = millis();
  DateTime now = rtc.now();

  long startSec = startHH * 3600L + startMN * 60L;
  long stopSec = stopHH * 3600L + stopMN * 60L;
  long nowSec = now.hour() * 3600L + now.minute() * 60L + now.second();

  if (nowSec < startSec || nowSec >= stopSec) {
    nextMode = true;
    isCooldown = false;
    confirmCount = 0;
    Serial.println(">>> [TIME]: OUT OF SCHEDULE, FORCE PEA <<<");
  }
  else {
    if (isCooldown) {
      if (currentMillis - cooldownStart >= 60000) {//60000 =1  MIN OR  300000=5MIN
        isCooldown = false;
        Serial.println(">>> [INFO]: COOLDOWN FINISHED! <<<");
      } else {
        nextMode = true;
        if (currentMillis % 3000 < 50) {
          float remainMin = (60000 - (currentMillis - cooldownStart)) / 60000.0;
          Serial.printf(">>> [STATUS]: COOLDOWN REMAIN: %.1f MIN <<<\n", remainMin);
        }
      }
    } else {
      if (v1 < vLowLimit) {
        nextMode = true;
        isCooldown = true;
        cooldownStart = currentMillis;
        Serial.println(">>> [EVENT]: V1 DROP! START 5 MIN COOLDOWN <<<");
      } else if (v1 > vHighLimit) {
        nextMode = false;
        confirmCount = 0;
      }
    }
  }

  if (nextMode!= gridMode) {
    if (nextMode == false) {
     // digitalWrite(PIN_PEA, LOW); delay(100);
     // digitalWrite(PIN_INV, HIGH);
      gridMode = false;
     // Serial.println(">>> [ACTION]: SWITCH TO INV <<<");
    } else {
    //  digitalWrite(PIN_INV, LOW); delay(100);
    //  digitalWrite(PIN_PEA, HIGH);
      gridMode = true;
    //  Serial.println(">>> [ACTION]: SWITCH TO PEA <<<");
    }
  }
}



void setRtcFromMqtt(String msg) {
  int hh = -1, mm = -1, ss = 0;
  msg.trim();

  if (msg.startsWith("{")) {
    JsonDocument doc;
    DeserializationError err = deserializeJson(doc, msg);
    if (!err) {
      hh = doc["hh"] | -1;
      mm = doc["mm"] | -1;
      ss = doc["ss"] | 0;
    }
  } else if (msg.indexOf(":") >= 0) {
    sscanf(msg.c_str(), "%d:%d:%d", &hh, &mm, &ss);
  }

  if (hh >= 0 && hh < 24 && mm >= 0 && mm < 60 && ss >= 0 && ss < 60) {
    DateTime now = rtc.now();
    rtc.adjust(DateTime(now.year(), now.month(), now.day(), hh, mm, ss));
   
    Serial.printf(">>> [MQTT]: RTC SET %02d:%02d:%02d <<<\n", hh, mm, ss);
    publishRTCTime();

    lcd.clear();
    lcd.setCursor(0,0); lcd.print("MQTT RTC SET");
    lcd.setCursor(0,1); lcd.printf("%02d:%02d:%02d", hh, mm, ss);
    delay(300);
    lcd.clear();
  } else {
    Serial.println(">>> [MQTT]: RTC format invalid");
  }
}

void setRtcDateFromMqtt(String msg) {
  int dd = -1, MM = -1, yyyy = -1;
  msg.trim();

  // รองรับทั้งแบบ JSON {"dd":15,"MM":1,"yyyy":2026}
  if (msg.startsWith("{")) {
    JsonDocument doc;
    DeserializationError err = deserializeJson(doc, msg);
    if (!err) {
      dd = doc["dd"] | -1;
      MM = doc["MM"] | -1;
      yyyy = doc["yyyy"] | -1;
    }
  }
  // รองรับแบบ String ข้อความตรงๆ "15.01.2000" หรือ "15.01.2026"
  else if (msg.indexOf(".") >= 0) {
    sscanf(msg.c_str(), "%d.%d.%d", &dd, &MM, &yyyy);
  }

  // ตรวจสอบความถูกต้องของ วัน (1-31), เดือน (1-12), ปี ค.ศ. (เช่น เกินปี 2000 ขึ้นไป)
  if (dd >= 1 && dd <= 31 && MM >= 1 && MM <= 12 && yyyy >= 2000) {
    DateTime now = rtc.now();
    // 💡 ล็อกค่าเวลาเดิม (now.hour, now.minute, now.second) ไว้ แล้วอัปเดตเฉพาะ วัน เดือน ปี ใหม่เข้าไป
    rtc.adjust(DateTime(yyyy, MM, dd, now.hour(), now.minute(), now.second()));
   
    Serial.printf(">>> [MQTT]: RTC DATE SET %02d.%02d.%04d <<<\n", dd, MM, yyyy);
   
    // แสดงผลที่หน้าจอ LCD ตัวเล็กของพี่ให้รับรู้
    lcd.clear();
    lcd.setCursor(0,0); lcd.print("MQTT DATE SET");
    lcd.setCursor(0,1); lcd.printf("%02d.%02d.%04d", dd, MM, yyyy);
    delay(300);
    lcd.clear();
  } else {
    Serial.println(">>> [MQTT]: RTC Date format invalid");
  }
}





void callback(char* topic, byte* payload, unsigned int length) {
  String msg = "";
  for (int i = 0; i < length; i++) {
    msg += (char)payload[i];
  }

  float newVal = msg.toFloat();
  Serial.printf("MQTT Recv Topic: %s, Msg: %s\n", topic, msg.c_str());
