void setup() {
  Serial.begin(115200);

  Wire.begin(21, 22);

  // 1. เริ่มระบบหน้าจอ TFT
  tft.init();
  tft.invertDisplay(false);
  tft.setRotation(1); // ตั้งหน้าจอแนวนอนครั้งเดียวพอครับ
  tft.fillScreen(TFT_BLACK);
  tft.setRotation(2); // ตั้งหน้าจอแนวนอนครั้งเดียวพอครับ
  tft.fillScreen(TFT_BLACK);
  tft.setRotation(3); // ตั้งหน้าจอแนวนอนครั้งเดียวพอครับ
  tft.fillScreen(TFT_BLACK);
  tft.setRotation(1); // ตั้งหน้าจอแนวนอนครั้งเดียวพอครับ
  tft.fillScreen(TFT_BLACK);

  // 2. จองพื้นที่แรมสำหรับ Sprite (ใช้ 220x240 เพื่อไม่ให้ RAM เต็ม)
  spr.createSprite(220, 240);

  // 3. เริ่มระบบจอ LCD 16x4
  lcd.begin(16, 4);
  lcd.setBacklight(255);
  lcd.setCursor(0,0);  lcd.print(" < WELCOME TO >");
  lcd.setCursor(0,1);  lcd.print(" ZTT OFF GRID V.2");
  lcd.setCursor(0,2);  lcd.print(" MODEL.VER-002");
  delay(2000);

  rtc.begin();

  pcf8574.pinMode(P0, OUTPUT);
  pcf8574.begin();
  pcf8574.digitalWrite(P0, HIGH);

  pinMode(PIN_V1, INPUT);
  pinMode(PIN_V2, INPUT);
  pinMode(PIN_V3, INPUT);
  pinMode(PIN_V4, INPUT);
  pinMode(NTC_Pin, INPUT);
  pinMode(PIN_CT, INPUT);

  pinMode(PIN_PEA, OUTPUT);
  pinMode(PIN_INV, OUTPUT);

  pinMode(PIN_LED_SUN, OUTPUT);
  pinMode(PIN_LED_PEA, OUTPUT);

  pinMode(25, INPUT_PULLUP);
  pinMode(PIN_SET_MODE, INPUT_PULLUP);
  pinMode(PIN_SET_UP, INPUT_PULLUP);
  pinMode(PIN_SET_SAVE, INPUT_PULLUP);

  // --- ดึงค่าตัวคูณจากบ้าน solar_cal ---
  prefs.begin("solar_cal", false);
  MULT_V1 = prefs.getFloat("v1_cal", MULT_V1);
  MULT_V2 = prefs.getFloat("v2_cal", MULT_V2);
  MULT_V3 = prefs.getFloat("v3_cal", MULT_V3);
  MULT_V4 = prefs.getFloat("v4_cal", MULT_V4);
  prefs.end();

  prefs.begin("solar_cal", true); // true = read-only
  bool cfgOK = prefs.getBool("cfg_ok", false);

  if (cfgOK) {
    MULT_V1 = prefs.getFloat("v1_cal", 97.0);
    MULT_V2 = prefs.getFloat("v2_cal", 21.0);
    MULT_V3 = prefs.getFloat("v3_cal", 79.5);
    MULT_V4 = prefs.getFloat("v4_cal", 79.5);
    vLowLimit = prefs.getFloat("vLow", 205.0);
    vHighLimit = prefs.getFloat("vHigh", 215.0);
    NTC_OFFSET = prefs.getFloat("ntc_off", 15.3);

    vHighThreshold = prefs.getFloat("vHighTh", 53.9);
    vLowThreshold = prefs.getFloat("vLowTh", 52.2);

    Serial.println(">>> [BOOT]: Load config from NVS OK");
  } else {
    Serial.println(">>> [BOOT]: NVS CORRUPT! Use default value");
  }
  startHH = prefs.getInt("sHH", 9);
  startMN = prefs.getInt("sMN", 0);
  stopHH = prefs.getInt("tHH", 15);
  stopMN = prefs.getInt("tMN", 0);
  prefs.end();

  readSensors();
  DateTime now = rtc.now();
  int bootTime = (now.hour() * 100) + now.minute();
  int startTimeSet = startHH * 100 + startMN;
  int stopTimeSet = stopHH * 100 + stopMN;

  if (bootTime >= startTimeSet && bootTime <= stopTimeSet && v1 > vHighLimit) {
    gridMode = false;
  }

  // 4. เริ่มต่อ WiFi และกำหนด MQTT Server ก่อน
  WiFi.begin();
  Serial.println(">>> [BOOT]: WiFi connecting... <<<");

  client.setServer(server1, 1883);
  client2.setServer(server2, 16832);
  client.setCallback(callback);
  client2.setCallback(callback);

  // 5. เชื่อมต่อ WiFi ให้สำเร็จก่อนสั่ง client.publish()
  if (WiFi.status() == WL_CONNECTED) {
    reconnect(); // เรียก reconnect เพื่อเชื่อมต่อ MQTT ให้ผ่านก่อน

    // ✅ ย้ายการสั่ง Publish มาไว้ตรงนี้ (หลังจากเชื่อมต่อสำเร็จแล้วเท่านั้น)
    client.publish("saraphi03/status/boost2", "", true);
    client2.publish("saraphi03/status/boost2", "", true);
    delay(200);
    client.publish("saraphi03/status/boost2", "ON", true);
    client2.publish("saraphi03/status/boost2", "ON", true);

    for(int i=0; i<10; i++){
      client.loop();
      client2.loop();
      delay(100);
    }
  }

  Serial.println(">>> [BOOT]: Setup done, entering loop <<<");
  publishTimeStatus();

  breakerState = true;
}



void publishRTCTime() {
  DateTime now = rtc.now();
  char buf[25]; // 🔥 จุดแก้ 1: เพิ่มขนาดบัฟเฟอร์ให้พอสำหรับ "YYYY-MM-DD HH:MM:SS" (ใช้ 25 ปลอดภัยกว่า)
 
  // 🔥 จุดแก้ 2: เปลี่ยนจาก TIMEbuf มาเป็น buf ให้ตรงกับตัวแปรที่ประกาศไว้ข้างบน และใช้วางในคําสั่งถัดไป
  snprintf(buf, sizeof(buf), "%04d-%02d-%02d %02d:%02d:%02d",
           now.year(), now.month(), now.day(), now.hour(), now.minute(), now.second());

  // ส่งค่าขึ้น MQTT Broker ตัวที่ 1 และ 2 ตามตรรกะของคุณ
  client.publish("saraphi03/status/rtc_time", buf);
  client2.publish("saraphi03/status/rtc_time", buf);
  client.publish("saraphi03/status/rtc_date", buf);
  client2.publish("saraphi03/status/rtc_date", buf);

  Serial.printf(">>> PUB RTC: %s\n", buf);
}

void handleTimeSetting() {
  static unsigned long pressStart = 0;
  static bool wasLongPress = false;
  static unsigned long lastActivity = 0;

  if (editState > 0 && millis() - lastActivity > 30000) {
    editState = 0;
    setHH = 0; setMN = 0; setSC = 0;
    lcd.clear();
    Serial.println(">>> [MENU]: TIMEOUT -> EXIT <<<");
    return;
  }

  if (digitalRead(PIN_SET_MODE) == LOW) {
    lcd.clear();
    if (pressStart == 0) {
      pressStart = millis();
      wasLongPress = false;
      lastActivity = millis();
    }
    if (!wasLongPress && millis() - pressStart > 2000 && editState > 0) {
      wasLongPress = true;
      editState = 0;
      setHH = 0; setMN = 0; setSC = 0;
      lcd.clear();
      lcd.setCursor(0,0); lcd.print("EXIT NO SAVE");
      delay(2000);
      lcd.clear();
      Serial.println(">>> [MENU]: LONG PRESS -> EXIT NO SAVE <<<");
      while(digitalRead(PIN_SET_MODE) == LOW) delay(10);
    }
    if (!wasLongPress && millis() - pressStart > 2000 && editState == 0) {
      wasLongPress = true;
      editState = 6;
      startMN = 0;
      lcd.clear();
      Serial.println(">>> [MENU]: LONG PRESS -> START:HOUR <<<");
      while(digitalRead(PIN_SET_MODE) == LOW) delay(10);
    }
  } else {
    if (pressStart > 0) {
      if (!wasLongPress && millis() - pressStart > 50) {
        lastActivity = millis();
        if (editState == 0) {
          editState = 1;
          DateTime now = rtc.now();
          setHH = now.hour(); setMN = now.minute(); setSC = now.second();
          lcd.clear();
          Serial.println(">>> [MENU]: SHORT PRESS -> CLOCK SETTING <<<");
        } else {
          editState++;
          if (editState > 10) {
            editState = 0;
            setHH = 0; setMN = 0; setSC = 0;
            lcd.clear();
            Serial.println(">>> [MENU]: CIRCLE END -> EXIT NO SAVE <<<");
          } else {
            if (editState == 7) stopMN = 0;
            lcd.clear();
          }
        }
      }
    }
    pressStart = 0;
    wasLongPress = false;
  }

  if (editState > 0) {
    lastActivity = millis();

    if (digitalRead(PIN_SET_UP) == LOW) {
      lastActivity = millis();
      switch(editState) {
        case 1: setHH++; if(setHH > 23) setHH = 0; break;
        case 2: setMN++; if(setMN > 59) setMN = 0; break;
        case 3: setSC++; if(setSC > 59) setSC = 0; break;
        case 4: vLowLimit += 0.5; break;
        case 5: vHighLimit += 0.5; break;
        case 6: startHH++; if(startHH > 23) startHH = 0; break;
        case 7: startMN++; if(startMN > 59) startMN = 0; break;
        case 8: stopHH++; if(stopHH > 23) stopHH = 0; break;
        case 9: stopMN++; if(stopMN > 59) stopMN = 0; break;
      }
      delay(100);
    }

    if (digitalRead(PIN_SET_SAVE) == LOW) {
      delay(50);
      lastActivity = millis();
      if (editState <= 9) {
        switch(editState) {
          case 1: setHH--; if(setHH < 0) setHH = 23; break;
          case 2: setMN--; if(setMN < 0) setMN = 59; break;
          case 3: setSC--; if(setSC < 0) setSC = 59; break;
          case 4: vLowLimit -= 0.5; break;
          case 5: vHighLimit -= 0.5; break;
          case 6: startHH--; if(startHH < 0) startHH = 23; break;
          case 7: startMN--; if(startMN < 0) startMN = 59; break;
          case 8: stopHH--; if(stopHH < 0) stopHH = 23; break;
          case 9: stopMN--; if(stopMN < 0) stopMN = 59; break;
        }
        delay(150);
      }
      else if (editState == 10) {
        if (setHH!= 0 || setMN!= 0 || setSC!= 0) {
          DateTime current = rtc.now();
          rtc.adjust(DateTime(current.year(), current.month(), current.day(), setHH, setMN, setSC));
        }
        prefs.begin("solar_cal", false);
        prefs.putFloat("vLow", vLowLimit);
        prefs.putFloat("vHigh", vHighLimit);
        prefs.putInt("sHH", startHH);
        prefs.putInt("sMN", startMN);
        prefs.putInt("tHH", stopHH);
        prefs.putInt("tMN", stopMN);
        prefs.putBool("cfg_ok", true);
        prefs.end();
        publishTimeStatus(); // <<< เพิ่มบรรทัดนี้ ส่งเวลาไป Node-RED ทันที

        lcd.clear();
        lcd.setCursor(0, 0); lcd.print(" TIME UPDATED ");
        lcd.setCursor(0, 1); lcd.printf("%02d:%02d-%02d:%02d", startHH, startMN, stopHH, stopMN);
        delay(1000);
        editState = 0; setHH = 0; setMN = 0; setSC = 0;
        lcd.clear();
        while(digitalRead(PIN_SET_SAVE) == LOW) delay(10);
      }
    }

    lcd.setCursor(0, 0);
    switch(editState) {
      case 1: lcd.print("1.SET:HH BUTT.UP-DWN"); break;
      case 2: lcd.print("2.SET:MM BUTT.UP-DWN"); break;
      case 3: lcd.print("3.SET:SS BUTT.UP-DWN"); break;
      case 4: lcd.printf("4.SET:V-INV LO %.1fV ", vLowLimit); break;
      case 5: lcd.printf("5.SET:V-INV HI %.1fV ", vHighLimit); break;
      case 6: lcd.printf("6.START:HOUR %02d ", startHH); break;
      case 7: lcd.printf("7.START:MIN %02d ", startMN); break;
      case 8: lcd.printf("8.STOP :HOUR %02d ", stopHH); break;
      case 9: lcd.printf("9.STOP :MIN %02d ", stopMN); break;
      case 10: lcd.print("10.PRESS BUTTON SAVE"); break;//BUTT PIN14  TO SAVE
    }
    lcd.setCursor(0, 1);
    if (editState <= 3) lcd.printf("VAL: %02d:%02d:%02d ", setHH, setMN, setSC);
    else if (editState <= 5) lcd.printf("ADJ: %.1fV [M]EXIT", (editState == 4? vLowLimit : vHighLimit));
    else if (editState <= 9) lcd.printf("ADJ: %02d:%02d [M]EXIT", (editState <= 7? startHH : stopHH), (editState == 7? startMN : stopMN));
    else lcd.printf("%02d:%02d-%02d:%02d ", startHH, startMN, stopHH, stopMN);

    lcd.setCursor(0,2);
    lcd.print("HOLD [M]2s=CANCEL ");
  }
}


