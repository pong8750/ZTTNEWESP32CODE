    prefs.putFloat("ntc_off", NTC_OFFSET);
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED NTC_OFFSET: %.1f\n", NTC_OFFSET);
  }
  else if (topicStr == "saraphi03/set/rtc_time") {
    setRtcFromMqtt(msg);
  }

 else if (topicStr == "saraphi03/set/rtc_date"){
    setRtcDateFromMqtt(msg);
  }

  else if (topicStr == "saraphi03/cmd/boost") {
    if (msg == "1" || msg == "ON" || msg == "on") {
      manualBoost = true;
      //digitalWrite(PIN_BOOST, HIGH);
      magConnected = true;
      Serial.println(">>> [BOOST]: MANUAL BOOST = 1 (FORCE ON) <<<");
    } else {
      manualBoost = false;
      //digitalWrite(PIN_BOOST, LOW);
      magConnected = false;
      Serial.println(">>> [BOOST]: MANUAL BOOST = 0 (AUTO) <<<");
    }
    client.publish("saraphi03/status/manual_boost", manualBoost ? "1" : "0", true);
    client2.publish("saraphi03/status/manual_boost", manualBoost ? "1" : "0", true);
  }
  // 3. คำสั่ง Reboot
  else if (topicStr == "saraphi03/cmd/reboot" && msg == "1") {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("MQTT REBOOT CMD");
    digitalWrite(PIN_INV, HIGH);  
    delay(500);
    digitalWrite(PIN_INV, LOW);
     delay(500);
    digitalWrite(PIN_INV, HIGH);  
    delay(500);
    digitalWrite(PIN_INV, LOW);


    ESP.restart();
  }
  // 4. คำสั่งควบคุมแม็คนีติคแบบแมนนวล (ย้ายเข้าลูปเอลส์ให้ทำงานต่อได้ชัวร์)
  else if (topicStr == "saraphi03/cmd/manual") {
    if (msg == "SW1ON") {
      digitalWrite(PIN_PEA, HIGH);
      delay(10);
      client.publish("saraphi03/status/SW1", "ON", true);
      client2.publish("saraphi03/status/SW1", "ON", true);
    }
    else if (msg == "SW1OFF") {
      digitalWrite(PIN_PEA, LOW);
      client.publish("saraphi03/status/SW1", "OFF", true);
      client2.publish("saraphi03/status/SW1", "OFF", true);
    }
    else if (msg == "SW2ON") {
      digitalWrite(PIN_INV, HIGH);
      client.publish("saraphi03/status/SW2", "ON", true);
      client2.publish("saraphi03/status/SW2", "ON", true);
    }
    else if (msg == "SW2OFF") {
      digitalWrite(PIN_INV, LOW);
      client.publish("saraphi03/status/SW2", "OFF", true);
      client2.publish("saraphi03/status/SW2", "OFF", true);
    }
    //showmode(); // แสดงผลบน LCD ตามสถานะ
  }

  // ========================================================
  // ให้เอาโค้ดควบคุมพอร์ต PCF8574 มาวางตรงนี้!! (ก่อนปีกกาปิดสุดท้าย)
  // ========================================================
    // 5. คำสั่งควบคุมพอร์ต PCF8574 (ปรับปรุงให้รองรับ Topic แบบสั้น saraphi03/cmd/port0)
  else if (topicStr.startsWith("saraphi03/cmd/port")) {
   
    // เปลี่ยนมาใช้คำสั่งยาวทั้งหมดของข้อความ ลบออก 1 ตัวอักษร เพื่อดึงตัวสุดท้ายเสมอร้อยเปอร์เซ็นต์
    int portIndex = topicStr.substring(topicStr.length() - 1).toInt();
   
    // ตรวจสอบความถูกต้องของตำแหน่งพอร์ต (0-7)
    if (portIndex >= 0 && portIndex <= 7) {
      if (msg == "1" || msg == "ON" || msg == "on") {
        pcf8574.digitalWrite(portIndex, HIGH);
        Serial.printf(">>> PCF8574 Port %d -> ON\n", portIndex);

        //saraphi03/cmd/port0
        String statusTopic = "saraphi03/status/port" + String(portIndex);
        client.publish(statusTopic.c_str(), "1", true);
        client2.publish(statusTopic.c_str(), "1", true);
      }
      else if (msg == "0" || msg == "OFF" || msg == "off") {
        pcf8574.digitalWrite(portIndex, LOW);
        Serial.printf(">>> PCF8574 Port %d -> OFF\n", portIndex);
       
        String statusTopic = "saraphi03/status/port" + String(portIndex);
        client.publish(statusTopic.c_str(), "0", true);
        client2.publish(statusTopic.c_str(), "0", true);
      }
    }
  }


 
}


