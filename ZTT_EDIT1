    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED vHighTh: %.1f\n", vHighThreshold);
  }
// 🔥 เพิ่มตรงนี้: บล็อกตั้งค่าและเซฟแรงดันต่ำสุด (vLowThreshold)
  else if (topicStr == "saraphi03/set/vbat_tresh_low") {
    vLowThreshold = newVal;
    prefs.begin("solar_cal", false);
    prefs.putFloat("vLowTh", vLowThreshold); // บันทึกลงแฟลชโดยใช้คีย์ vLowTh
    prefs.putBool("cfg_ok", true);
    prefs.end();
    Serial.printf(">>> SAVED vLowTh: %.1f\n", vLowThreshold);
